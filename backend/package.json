{
  "name": "backend",
  "version": "1.0.0",
  "description": "Express TypeScript backend for the VedaAI Assessment Creator.",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/modules/generation/generation.worker.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "worker": "node dist/modules/generation/generation.worker.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "audit": "npm audit"
  },
  "keywords": [],
  "author": "",
  "license": "UNLICENSED",
  "type": "module",
  "dependencies": {
    "@bull-board/api": "^7.1.5",
    "@bull-board/express": "^7.1.5",
    "@google/genai": "^2.6.0",
    "bullmq": "^5.77.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "ioredis": "^5.10.1",
    "mongoose": "^9.6.2",
    "multer": "^2.1.1",
    "pdfkit": "^0.18.0",
    "socket.io": "^4.8.3",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.1",
    "@types/pdfkit": "^0.17.6",
    "@types/ws": "^8.18.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
